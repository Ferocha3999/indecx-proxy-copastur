      <div class="rsc rsc-a raten"><div class="rsl">Atencao</div><div class="rsv" id="rc-a">-</div><div class="rss">monitorar de perto</div></div>
      <div class="rsc rsc-e rest"><div class="rsl">Estavel</div><div class="rsv" id="rc-e">-</div><div class="rss">manter cadencia</div></div>

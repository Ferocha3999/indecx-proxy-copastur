.rfb{font-size:12px;color:var(--mut);background:var(--bg);border-radius:var(--rs);padding:8px 10px;margin-bottom:8px;line-height:1.5;font-style:italic;border-left:2px solid var(--brd2)}
.rcons{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:8px}
.rcon{font-size:11px;padding:2px 8px;border-radius:20px;background:var(--bg);color:var(--mut);border:1px solid var(--brd2)}
.rac{padding:10px 12px;border-radius:var(--rs);font-size:12px;line-height:1.55;display:flex;gap:8px;align-items:flex-start}
.rac-c{background:#FEF2F2;color:#991B1B;border:1px solid #FECACA}
.rac-a{background:#FFFBEB;color:#92400E;border:1px solid #FDE68A}
.rac-e{background:#EFF6FF;color:#1E40AF;border:1px solid #BFDBFE}
.rac-s{background:#F0FDF4;color:#14532D;border:1px solid #BBF7D0}
.spin{display:inline-block;width:14px;height:14px;border:2px solid var(--brd2);border-top-color:var(--mut);border-radius:50%;animation:spin .8s linear infinite}
.cur{display:inline-block;width:2px;height:14px;background:var(--txt);vertical-align:middle;animation:blink .7s infinite}
.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:9999;align-items:center;justify-content:center}
.ov.open{display:flex}
.om{background:var(--sur);border-radius:var(--r);width:500px;max-width:calc(100vw - 2rem);box-shadow:0 20px 60px rgba(0,0,0,.2)}
.omh{padding:1.25rem 1.5rem 1rem;border-bottom:1px solid var(--brd);display:flex;align-items:center;justify-content:space-between}
.omt{font-size:15px;font-weight:500;display:flex;align-items:center;gap:8px}
.omb{padding:1.5rem}
.of{margin-bottom:1rem}
.of label{font-size:12px;color:var(--mut);display:block;margin-bottom:6px;font-weight:500}
.of input{width:100%;padding:8px 10px;border:1px solid var(--brd2);border-radius:var(--rs);font-size:13px;background:var(--sur);color:var(--txt);outline:none;box-sizing:border-box;font-family:inherit}
.of input:focus{border-color:var(--txt)}
.of small{font-size:11px;color:var(--hin);margin-top:4px;display:block}
.ost{font-size:12px;padding:8px 12px;border-radius:var(--rs);margin-bottom:1rem;display:none}
.ost.ok{background:#F0FDF4;color:#14532D;border:1px solid #BBF7D0;display:block}
.ost.err{background:#FEF2F2;color:#991B1B;border:1px solid #FECACA;display:block}
.ost.ld{background:var(--bg);color:var(--mut);border:1px solid var(--brd);display:flex;align-items:center;gap:8px}
.oac{display:flex;gap:8px;justify-content:flex-end;margin-top:1.25rem}
.rim{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:9999;align-items:flex-start;justify-content:center;padding-top:60px}
.rim.open{display:flex}
.ribox{background:var(--sur);border-radius:var(--r);width:680px;max-width:calc(100vw - 2rem);max-height:80vh;overflow-y:auto}
.ribh{padding:1.5rem 1.5rem 1rem;border-bottom:1px solid var(--brd);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--sur)}
.ribt{font-size:16px;font-weight:500;display:flex;align-items:center;gap:8px}
.ribb{padding:1.5rem}
.rids{margin-bottom:1.25rem}
.ridt{font-size:11px;font-weight:500;letter-spacing:.06em;text-transform:uppercase;color:var(--mut);margin-bottom:.75rem;padding-bottom:.5rem;border-bottom:1px solid var(--brd)}
.riig{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:1.25rem}
.rii{background:var(--bg);border-radius:var(--rs);padding:1rem;border:1px solid var(--brd)}
.riil{font-size:10px;letter-spacing:.06em;text-transform:uppercase;color:var(--hin);margin-bottom:6px}
.riiv{font-size:20px;font-weight:500;font-family:"DM Mono",monospace}
.riis{font-size:12px;color:var(--mut);margin-top:4px}
.rirl{display:flex;flex-direction:column;gap:6px}
.rirr{display:flex;align-items:center;gap:10px;font-size:13px}
.rirp{font-size:11px;font-family:"DM Mono",monospace;color:var(--hin);width:16px;flex-shrink:0}
.rirn{flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.rirbw{width:80px;height:6px;background:var(--brd);border-radius:20px;overflow:hidden;flex-shrink:0}
.rirbf{height:100%;border-radius:20px}
.rirv{font-size:12px;font-family:"DM Mono",monospace;color:var(--mut);width:30px;text-align:right;flex-shrink:0}
.risum{background:var(--bg);border-radius:var(--rs);padding:1rem 1.25rem;font-size:13px;color:var(--mut);line-height:1.7;border-left:3px solid var(--txt);min-height:60px}
.idl{display:flex;flex-direction:column;gap:8px}
.idli{display:flex;gap:10px;align-items:flex-start;padding:10px 12px;background:var(--bg);border-radius:var(--rs);font-size:13px;color:var(--mut);line-height:1.5}
.sec{display:none}.sec.on{display:block}
</style>
</head>
<body>

<div class="ov" id="ov-indecx">
  <div class="om">
    <div class="omh"><div class="omt"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>Conectar com Indecx</div><button onclick="closeModal('ov-indecx')" style="background:none;border:none;cursor:pointer;color:var(--mut);font-size:22px;line-height:1">x</button></div>
    <div class="omb">
      <div class="ost" id="ind-status"></div>
      <div class="of"><label>URL do Proxy</label><input type="text" id="ind-proxy" placeholder="https://indecx-proxy-copastur.onrender.com"><small>URL gerada pelo Render</small></div>
      <div class="of"><label>Company Key</label><input type="password" id="ind-key" placeholder="$2b$10$..."><small>Painel Indecx -> Configuracoes -> Integracoes -> API</small></div>
      <div class="of"><label>Identificador da acao</label><input type="text" id="ind-action" value="all"><small>Use "all" para buscar todas as acoes ou clique em "Ver acoes" para descobrir o identificador correto</small></div>
      <div class="of"><label>Periodo</label><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px"><input type="text" id="ind-start" value="2026-01-01" placeholder="YYYY-MM-DD"><input type="text" id="ind-end" value="2026-03-31" placeholder="YYYY-MM-DD"></div><small>Formato: YYYY-MM-DD (ex: 2026-01-01)</small></div>
      <div class="oac"><button class="btn" onclick="closeModal('ov-indecx')">Cancelar</button><button class="btn" onclick="verAcoes()">Ver acoes</button><button class="btn btn-i" onclick="testConn()">Testar conexao</button><button class="btn btn-p" onclick="loadIndecx()">Carregar dados</button></div>
    </div>
  </div>
</div>
<div class="rim" id="ov-resumo">
  <div class="ribox">
    <div class="ribh"><div class="ribt"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>Resumo inteligente</div><button onclick="closeModal('ov-resumo')" style="background:none;border:none;cursor:pointer;color:var(--mut);font-size:22px;line-height:1">x</button></div>
    <div class="ribb">
      <div class="rids"><div class="ridt">Numeros do periodo</div><div class="riig"><div class="rii"><div class="riil">NPS Score</div><div class="riiv">+90</div><div class="riis">Jan-Mar 2026 - excepcional</div></div><div class="rii"><div class="riil">Nota media</div><div class="riiv">9.5</div><div class="riis">Base: 1.322 respostas</div></div><div class="rii"><div class="riil">Promotores</div><div class="riiv" id="ri-pro">1.219</div><div class="riis">92% do total</div></div><div class="rii"><div class="riil">Neutros</div><div class="riiv" id="ri-neu">70</div><div class="riis">5% - oportunidade</div></div></div></div>
      <div class="rids"><div class="ridt">Top clientes por nota</div><div class="rirl" id="ri-clientes"></div></div>
      <div class="rids"><div class="ridt">Analise do periodo</div><div class="risum" id="ri-resumo"></div></div>
      <div class="rids"><div class="ridt">Sugestoes de acao</div><div class="idl" id="ri-ideias"></div></div>
    </div>
  </div>
</div>

<div class="layout">
<aside class="sb">
  <div class="logo"><div class="logo-dot"></div>NPS Copastur</div>
  <nav class="nav">
    <div class="nl">Visualizacoes</div>
    <button class="ni on" onclick="showTab('overview',this)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>Visao geral</button>
    <button class="ni" onclick="showTab('clientes',this)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>Clientes</button>
    <button class="ni" onclick="showTab('elogios',this)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>Elogios</button>
    <button class="ni" onclick="showTab('swot',this)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="8" height="8" rx="1"/><rect x="13" y="3" width="8" height="8" rx="1"/><rect x="3" y="13" width="8" height="8" rx="1"/><rect x="13" y="13" width="8" height="8" rx="1"/></svg>SWOT</button>
    <button class="ni" onclick="showTab('enc',this)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>Encantamento</button>
    <button class="ni" onclick="showTab('metricas',this)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>Metricas clientes</button>
    <button class="ni" onclick="showTab('risco',this)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>Mapa de risco</button>
    <button class="ni" onclick="showTab('radar',this)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><line x1="2" y1="12" x2="22" y2="12"/></svg>Radar de contexto</button>
  </nav>
  <div class="sb-bot">
    <button class="btn-dash" onclick="openModal('ov-resumo');renderResumo()"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>Resumo IA</button>
    <div class="pill"><div class="dot-g" id="conn-dot"></div><span id="conn-lbl">Dados exemplo</span></div>
  </div>
</aside>
<main class="main">
  <div class="ph">
    <div><div class="pt">Painel CX</div><div class="ps" id="page-sub">Centralidade no cliente - Jan-Mar 2026 - 1.322 respostas</div></div>
    <div class="ha">
      <button class="btn btn-i" onclick="openModal('ov-indecx')"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>Conectar Indecx</button>
      <button class="btn" onclick="document.getElementById('fin').click()"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg><span id="flabel">Planilha</span></button>
      <input type="file" id="fin" accept=".xlsx,.xls,.csv" style="display:none" onchange="loadFile(this)">
      <button class="btn btn-p"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>Processar com IA</button>
    </div>
  </div>
  <div id="sec-overview" class="sec on">
    <div class="metrics">
      <div class="mc"><div class="mc-l">Promotores</div><div class="mc-v vp" id="m-pro">1.219</div><div class="mc-s">92% das respostas</div></div>
      <div class="mc"><div class="mc-l">Neutros</div><div class="mc-v vn" id="m-neu">70</div><div class="mc-s">5% - contato em 48h</div></div>
      <div class="mc"><div class="mc-l">NPS Score</div><div class="mc-v" id="m-nps">+90</div><div class="mc-s" style="color:#16A34A">Resultado excepcional</div></div>
    </div>
    <div class="two">
      <div class="card" style="margin-bottom:0"><div class="ct">Tendencia NPS - Jan a Mar 2026</div><canvas id="chart-trend" height="190" style="width:100%;display:block"></canvas></div>
      <div class="card" style="margin-bottom:0">
        <div class="ct">Distribuicao - Jan-Mar 2026</div>
        <div class="dbar"><div class="dp" id="bar-pro" style="width:95%"></div><div class="dn" id="bar-neu" style="width:5%"></div></div>
        <div class="dleg"><span><span class="dd" style="background:#4A8C35"></span><span id="leg-pro">Promotores 95%</span></span><span><span class="dd" style="background:#C8961A"></span><span id="leg-neu">Neutros 5%</span></span></div>
        <div class="ct">Categorias do feedback</div>
        <div class="cats" id="cat-list"></div>
      </div>
    </div>
    <div class="card" style="margin-top:1.25rem"><div class="ct">O que os clientes estao dizendo</div><div class="wc" id="wordcloud"></div></div>
    <div class="card" style="margin-top:1.25rem;margin-bottom:0"><div class="ct">NPS por mes</div><canvas id="chart-bar" height="160" style="width:100%;display:block"></canvas></div>
  </div>
  <div id="sec-clientes" class="sec">
    <div class="flt">
      <button class="fb on" onclick="filterC('todos',this)">Todos</button>
      <button class="fb" onclick="filterC('Promotor',this)">Promotores</button>
      <button class="fb" onclick="filterC('Neutro',this)">Neutros</button>
      <div class="sw"><svg class="si" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg><input type="text" placeholder="Buscar cliente ou empresa..." oninput="searchC(this.value)"></div>
    </div>
    <div class="clist" id="client-list"></div>
  </div>
  <div id="sec-elogios" class="sec">
    <div class="ecg">
      <div class="ecs"><div class="mc-l">Elogios identificados</div><div class="mc-v" id="el-tot">-</div><div class="mc-s">com contexto emocional</div></div>
      <div class="ecs"><div class="mc-l">E-mails prontos</div><div class="mc-v" id="el-em">-</div><div class="mc-s">cliente - atendente - gestor</div></div>
    </div>
    <div id="elogios-list"></div>
  </div>
  <div id="sec-swot" class="sec">

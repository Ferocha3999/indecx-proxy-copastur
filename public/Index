body{font-family:"DM Sans",sans-serif;background:var(--bg);color:var(--txt);font-size:14px;line-height:1.6;min-height:100vh}
.layout{display:flex;min-height:100vh}
.sb{width:220px;flex-shrink:0;background:var(--sur);border-right:1px solid var(--brd);padding:2rem 1.25rem;display:flex;flex-direction:column;gap:1.5rem;position:sticky;top:0;height:100vh;overflow-y:auto}

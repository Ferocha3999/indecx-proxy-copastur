    <div id="risco-list"></div>
  </div>
  <div id="sec-radar" class="sec">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.5rem;gap:12px;flex-wrap:wrap">
      <div><h2 class="pt">Radar de contexto</h2><p class="ps">Eventos externos que podem impactar o NPS - busca em tempo real</p></div>
      <button class="btn btn-p" id="radar-btn" onclick="buscarRadar()"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>Buscar eventos agora</button>
    </div>
    <div id="radar-empty" style="background:var(--sur);border:1px solid var(--brd);border-radius:var(--r);padding:3rem;text-align:center">
      <div style="font-size:36px;margin-bottom:12px">&#127758;</div>
      <div style="font-size:15px;font-weight:500;margin-bottom:6px">Radar ainda nao executado</div>
      <div style="font-size:13px;color:var(--mut);margin-bottom:16px">Clique em Buscar eventos agora para a IA pesquisar eventos reais de Jan-Mar 2026 e correlacionar com os dados de NPS da Copastur.</div>

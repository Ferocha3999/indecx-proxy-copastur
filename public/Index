    <div class="metrics">
      <div class="mc"><div class="mc-l">Empresas</div><div class="mc-v">129</div><div class="mc-s">respondentes no periodo</div></div>
      <div class="mc"><div class="mc-l">Maior volume</div><div class="mc-v" style="font-size:18px">White Martins</div><div class="mc-s">9 respostas - media 9.6</div></div>
      <div class="mc"><div class="mc-l">Nota 10 perfeita</div><div class="mc-v" id="mc-perf">-</div><div class="mc-s">empresas com media 10.0</div></div>
    </div>
    <div class="flt">
      <button class="fb on" onclick="mcSort('total',this)">Por volume</button>
      <button class="fb" onclick="mcSort('media',this)">Por nota media</button>
      <button class="fb" onclick="mcSort('promotores',this)">Por promotores</button>

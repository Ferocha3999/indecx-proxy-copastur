      <button class="fb" onclick="riscoFilt('atencao',this)">Atencao</button>
      <button class="fb" onclick="riscoFilt('estavel',this)">Estavel</button>
      <button class="fb" onclick="riscoFilt('seguro',this)">Seguro</button>
      <div class="sw"><svg class="si" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg><input type="text" placeholder="Buscar empresa..." oninput="riscoSearch(this.value)"></div>

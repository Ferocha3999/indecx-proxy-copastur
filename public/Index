      <div><h2 class="pt">Analise SWOT</h2><p class="ps">Gerada a partir dos dados reais - Jan-Mar 2026</p></div>
      <button class="btn" onclick="renderSwot()"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>Atualizar</button>
    </div>
    <div class="swotg" id="swot-grid"></div>
    <div class="ssum"><div class="sstit">Resumo estrategico</div><div class="sstxt" id="swot-res"></div><div class="stags" id="swot-tags"></div></div>
  </div>
  <div id="sec-enc" class="sec">
    <div class="ecg">
      <div class="ecs"><div class="mc-l">Acoes identificadas</div><div class="mc-v" id="enc-tot">-</div><div class="mc-s">oportunidades de encantar</div></div>
      <div class="ecs"><div class="mc-l">Tipos de acao</div><div class="mc-v" id="enc-tipos">-</div><div class="mc-s">categorias diferentes</div></div>
    </div>
    <div class="flt" id="enc-filtros"></div>
    <div id="enc-list"></div>
  </div>
  <div id="sec-metricas" class="sec">

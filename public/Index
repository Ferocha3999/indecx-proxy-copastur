function sparkline(m1,m2,m3){
  var pts=[m1,m2,m3].filter(function(v){return v!==null&&v!==undefined;});
  if(pts.length<2)return '';
  var w=60,h=24,pad=3;
  var min=Math.min.apply(null,pts)-0.5;var max=Math.max.apply(null,pts)+0.5;
  var coords=pts.map(function(v,i){var x=pad+i*(w-pad*2)/(pts.length-1);var y=h-pad-((v-min)/(max-min||1))*(h-pad*2);return x.toFixed(1)+','+y.toFixed(1);});

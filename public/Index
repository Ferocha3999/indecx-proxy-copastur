  setStatus('Buscando dados na Indecx...','ld');
  var params=new URLSearchParams({limit:1000});
  if(start)params.append('startDate',start);if(end)params.append('endDate',end);
  fetch(proxy+'/nps?'+params.toString(),{headers:{'company-key':key}})
    .then(function(r){return r.ok?r.json():r.json().then(function(e){throw new Error(e.error||'Status '+r.status);});})
    .then(function(data){
      var novos=data.dados||[];
      if(!novos.length){setStatus('Nenhum dado encontrado para o periodo.','err');return;}
      DADOS.length=0;novos.forEach(function(d){DADOS.push(d);});
      var pros=DADOS.filter(function(d){return d.tipo==='Promotor';}).length;
      var neus=DADOS.filter(function(d){return d.tipo==='Neutro';}).length;
      var tot=DADOS.length;
      var nps=Math.round(((pros-(tot-pros-neus))/tot)*100);
      var pm=document.getElementById('m-pro');if(pm)pm.textContent=pros;
      var nm=document.getElementById('m-neu');if(nm)nm.textContent=neus;
      var nm2=document.getElementById('m-nps');if(nm2)nm2.textContent=(nps>=0?'+':'')+nps;
      var ps=document.getElementById('page-sub');if(ps)ps.textContent='Indecx - '+tot+' respostas - '+start+' a '+end;
      var cd=document.getElementById('conn-dot');if(cd)cd.className='dot-g';
      var cl=document.getElementById('conn-lbl');if(cl)cl.textContent='Indecx conectado';
      chartsInit=false;renderClientes();renderCharts();
      setStatus(tot+' respostas carregadas - '+pros+'P '+neus+'N - NPS '+(nps>=0?'+':'')+nps,'ok');
      setTimeout(function(){closeModal('ov-indecx');},2000);
    })
    .catch(function(e){setStatus('Erro: '+e.message,'err');});
}
function loadFile(input){
  var file=input.files[0];if(!file)return;
  var fl=document.getElementById('flabel');if(fl)fl.textContent='Lendo...';
  var reader=new FileReader();
  reader.onload=function(e){
    try{
      var data=new Uint8Array(e.target.result);var wb;
      try{wb=XLSX.read(data,{type:'array',cellDates:true,raw:false});}catch(err){var txt=new TextDecoder('utf-8').decode(data);wb=XLSX.read(txt,{type:'string'});}
      var ws=wb.Sheets[wb.SheetNames[0]];var rows=XLSX.utils.sheet_to_json(ws,{defval:'',raw:false});
      if(!rows.length){alert('Planilha vazia.');if(fl)fl.textContent='Planilha';return;}
      function campo(row,ops){for(var i=0;i<ops.length;i++){for(var k in row){if(k.toLowerCase().trim()===ops[i].toLowerCase())return String(row[k]||'').trim();}}return '';}
      function calcCls(nota){var n=parseFloat(String(nota).replace(',','.'));if(isNaN(n))return null;if(n>=9)return 'Promotor';if(n>=7)return 'Neutro';return 'Detrator';}
      var novos=rows.map(function(r){return{nome:campo(r,['nome','name','passageiro','cliente']),empresa:campo(r,['empresa','company','grupo_cliente']),email:campo(r,['email','e-mail']),nota:parseInt(campo(r,['nota','note','score','nps']))||0,feedback:campo(r,['feedback','comentario','comentarios','resposta']),consultor:campo(r,['consultor','agente','cs']),categorias_raw:campo(r,['categorias','keywords','topicos'])};}).filter(function(r){return r.nome&&r.nome!=='nan'&&r.nota;}).map(function(r){return Object.assign({},r,{tipo:calcCls(r.nota),categorias:r.categorias_raw?r.categorias_raw.split(',').map(function(c){return c.trim();}).filter(Boolean).slice(0,3):[],email_body:''});}).filter(function(r){return r.tipo==='Promotor'||r.tipo==='Neutro';});
      if(!novos.length){alert('Nenhum promotor ou neutro encontrado.\n\nColunas: '+Object.keys(rows[0]).join(', '));if(fl)fl.textContent='Planilha';return;}
      DADOS.length=0;novos.forEach(function(d){DADOS.push(d);});
      var pros=DADOS.filter(function(d){return d.tipo==='Promotor';}).length;
      var neus=DADOS.filter(function(d){return d.tipo==='Neutro';}).length;
      var pm=document.getElementById('m-pro');if(pm)pm.textContent=pros;
      var nm=document.getElementById('m-neu');if(nm)nm.textContent=neus;
      var ps=document.getElementById('page-sub');if(ps)ps.textContent='Dados carregados - '+DADOS.length+' respostas';
      if(fl)fl.textContent='OK: '+file.name.replace(/\.[^.]+$/,'').substring(0,18);
      chartsInit=false;renderClientes();renderCharts();
      alert('Carregado: '+DADOS.length+' clientes | Promotores: '+pros+' | Neutros: '+neus);
    }catch(err){alert('Erro ao ler o arquivo: '+err.message);if(fl)fl.textContent='Planilha';}
  };
  reader.onerror=function(){alert('Nao foi possivel ler o arquivo.');if(fl)fl.textContent='Planilha';};
  reader.readAsArrayBuffer(file);
}

function verAcoes(){
  var proxy=(document.getElementById('ind-proxy')||{}).value||'';
  var key=(document.getElementById('ind-key')||{}).value||'';
  proxy=proxy.trim().replace(/\/$/,'');key=key.trim();
  if(!proxy){setStatus('Informe a URL do proxy.','err');return;}
  if(!key){setStatus('Informe a company key.','err');return;}
  setStatus('Buscando acoes disponíveis...','ld');
  fetch(proxy+'/actions',{headers:{'company-key':key}})
    .then(function(r){return r.ok?r.json():r.json().then(function(e){throw new Error(e.error||'Status '+r.status);});})
    .then(function(d){
      var acoes=d.actions||d||[];
      if(!acoes.length){setStatus('Nenhuma acao encontrada.','err');return;}
      var lista=acoes.map(function(a){return a.identifier+' — '+a.name;}).join('\n');
      setStatus('Acoes encontradas: '+acoes.length+'. Veja o console para detalhes.','ok');
      var el=document.getElementById('ind-action');
      if(el&&acoes.length===1)el.value=acoes[0].identifier;
      alert('Acoes disponíveis:\n\n'+lista+'\n\nO campo "Identificador da acao" foi preenchido automaticamente com a primeira acao.');
      if(el&&acoes[0])el.value=acoes[0].identifier;
    })
    .catch(function(e){setStatus('Erro: '+e.message,'err');});
}

document.addEventListener('DOMContentLoaded',function(){
  renderClientes();
  renderWordcloud();
  renderCats();
  setTimeout(renderCharts,100);
});

